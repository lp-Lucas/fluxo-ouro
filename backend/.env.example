# Backend do Fluxo Ouro — variáveis de ambiente (copie para .env; NUNCA comite o .env real).
# As chaves ficam SÓ aqui no backend, nunca no frontend/bundle/git.
PORT=3001

# ── IA (autocut, cobertura de legenda, FLOW: detecção + prompt de motion) ──
# Por padrão usa o CLI `claude` já logado no Claude Code (sem chave). Com a chave abaixo,
# passa a usar a API Anthropic direta (mais barato/rápido). Modelo opcional.
# ANTHROPIC_API_KEY=
# AUTOCUT_MODEL=claude-sonnet-5

# ── FLOW: imagem (design das frases) ──
# Provider: openai (padrão) | gemini
IMAGE_PROVIDER=openai
# FLOW_PROMPT_AUTHOR=claude       # claude = Claude escreve o prompt de design (Fase 1); raw = comportamento atual (delta cru + identidade)
OPENAI_API_KEY=sk-proj-COLE_A_SUA_CHAVE_AQUI   # NUNCA comite a chave real — .env.example é template
# OPENAI_IMAGE_MODEL=gpt-image-2   # padrão (segue refs fiel, ~2min); use gpt-image-1 p/ + rápido
# OPENAI_IMAGE_QUALITY=high        # low|medium|high|auto
# GEMINI_API_KEY=

# ── FLOW: vídeo (motion image-to-video) ──
# Provider: google (padrão). Confirme o modelo/endpoint do Veo na doc atual do Google.
VIDEO_PROVIDER=google
GOOGLE_VIDEO_API_KEY=
# GOOGLE_VIDEO_MODEL=veo-3.0-generate-001
# GOOGLE_API_BASE=https://generativelanguage.googleapis.com/v1beta
